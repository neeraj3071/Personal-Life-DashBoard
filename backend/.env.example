NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/dailyorbit"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# CORS
FRONTEND_URL=http://localhost:3000
# Allow all https://*.vercel.app preview URLs when true
CORS_ALLOW_VERCEL_PREVIEWS=false

# Public frontend app URL used in reminder email links
APP_BASE_URL=http://localhost:3000

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Daily Reminder Emails (Gmail SMTP)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
GMAIL_FROM="Daily Orbit <your_gmail_address@gmail.com>"

# Reminder Scheduler
REMINDER_ENABLED=false
# Use semicolon-separated cron entries for 2-3 reminders/day
REMINDER_CRON_LIST="0 9 * * *;0 14 * * *;0 20 * * *"
# Topics rotate across cron slots (comma-separated)
REMINDER_TOPICS="exercise,mood,habits"
# Legacy single cron fallback (optional)
REMINDER_CRON="0 9 * * *"
REMINDER_TIMEZONE=UTC

# Optional admin key for manual send-all endpoint
REMINDER_ADMIN_KEY=your_secure_admin_key
