# Daily Orbit backend env for Render (Web Service)
# Copy these into Render -> Environment, or use this as your local reference.

NODE_ENV=production

# Use the exact connection string from Render Postgres if available.
# If building manually, replace placeholders below.
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@dpg-d6qpdk450q8c73bmt77g-a:5432/<DB_NAME>?sslmode=require

# Security
JWT_SECRET=<GENERATE_A_LONG_RANDOM_SECRET>
JWT_EXPIRES_IN=7d

# CORS + frontend links
FRONTEND_URL=https://daily-orbit-six.vercel.app,https://daily-orbit-bmxwxgs3m-neeraj3071s-projects.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=true
APP_BASE_URL=https://daily-orbit-six.vercel.app

# AI (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email reminders (optional)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM="Daily Orbit <your_gmail_address@gmail.com>"
REMINDER_ENABLED=false
REMINDER_CRON_LIST="0 9 * * *;0 14 * * *;0 20 * * *"
REMINDER_TOPICS="exercise,mood,habits"
REMINDER_CRON="0 9 * * *"
REMINDER_TIMEZONE=UTC
REMINDER_ADMIN_KEY=<GENERATE_ANOTHER_RANDOM_SECRET>

# Google OAuth (optional; only if you add server-side Google auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
